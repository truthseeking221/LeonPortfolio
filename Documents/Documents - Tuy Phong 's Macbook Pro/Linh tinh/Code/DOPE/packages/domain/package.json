{
  "name": "@dope/domain",
  "version": "0.0.1",
  "description": "DOPE domain logic - pure state machines and business rules",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "dope",
    "domain",
    "state-machine"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@dope/contracts": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@dope/contracts": {
      "optional": true
    }
  }
}

